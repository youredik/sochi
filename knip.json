{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"ignoreDependencies": [
		"pino-pretty"
	],
	"workspaces": {
		"apps/backend": {
			"includeEntryExports": true,
			"project": ["src/**/*.ts"],
			"ignore": ["src/tests/**"]
		},
		"apps/frontend": {
			"project": ["src/**/*.{ts,tsx}"]
		},
		"packages/shared": {
			"project": ["src/**/*.ts"],
			"includeEntryExports": true
		}
	}
}
