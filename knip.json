{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"ignoreDependencies": [
		"pino-pretty",
		"tailwindcss",
		"@lingui/cli",
		"@fontsource-variable/geist",
		"tw-animate-css",
		"shadcn",
		"axe-core",
		"happy-dom",
		"bun",
		"@stryker-mutator/command-runner"
	],
	"ignoreExportsUsedInFile": true,
	"workspaces": {
		"apps/backend": {
			"includeEntryExports": true,
			"project": ["src/**/*.ts"],
			"entry": [
				"src/lib/channel-manager/index.ts",
				"src/db/bench-schema-prefix.ts",
				"src/db/spike-bun-ydb.ts"
			],
			"ignore": ["src/tests/**"]
		},
		"apps/frontend": {
			"entry": ["lingui.config.ts"],
			"project": ["src/**/*.{ts,tsx}", "*.ts"],
			"ignore": ["src/components/ui/**"]
		},
		".": {
			"entry": ["tests/e2e/*.ts"],
			"project": ["tests/**/*.ts"]
		},
		"packages/shared": {
			"project": ["src/**/*.ts"]
		}
	}
}
