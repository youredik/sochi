{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"ignoreDependencies": [
		"pino-pretty",
		"tailwindcss",
		"@lingui/cli",
		"@fontsource-variable/geist",
		"tw-animate-css",
		"shadcn"
	],
	"ignoreExportsUsedInFile": true,
	"workspaces": {
		"apps/backend": {
			"includeEntryExports": true,
			"project": ["src/**/*.ts"],
			"ignore": ["src/tests/**"]
		},
		"apps/frontend": {
			"entry": ["lingui.config.ts"],
			"project": ["src/**/*.{ts,tsx}", "*.ts"]
		},
		".": {
			"entry": ["tests/e2e/*.ts"],
			"project": ["tests/**/*.ts"]
		},
		"packages/shared": {
			"project": ["src/**/*.ts"],
			"includeEntryExports": true
		}
	}
}
