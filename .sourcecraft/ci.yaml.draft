#
# This file is .draft suffix INTENTIONALLY (renamed from ci.yaml) — SourceCraft
# не picks up .draft extension. Reasons:
#
#   1. revision-deploy task uses `cube: yc-sls-container-deploy` syntax which
#      research subagent 2026-05-19 EMPIRICALLY REFUTED. SourceCraft canon
#      requires either:
#        (a) native cube: `image: cr.yandex/sourcecraft/yc-iam:latest` + script:
#        (b) GH-Actions bridge: `action: yc-actions/yc-sls-container-deploy@v4`
#      (`uses:` syntax is GH Actions, NOT SourceCraft.)
#
#   2. Quality / infra-plan / infra-apply workflows NOT end-to-end verified.
#      Current deploy was MANUAL via `yc serverless container revision deploy`
#      + `aws s3 sync` (Day 0/1 manual deploy log in handover memo).
#
# DO NOT rename back к ci.yaml until BOTH:
#   - Action-syntax replacement verified against current SourceCraft docs +
#     successful run on test PR/branch
#   - Empirical smoke: full deploy через CI produces working revision
#
# Rename trigger: Day 2 CI fix task per handover_2026_05_19.md
#
# =============================================================================
# Sochi HoReCa — SourceCraft CI/CD (Q2 2026 canon — DRAFT pending verification)
# =============================================================================
#
# Workflows:
#   - `quality`  — tests + typecheck on PR/push
#   - `infra-plan` — `tofu plan` on PR с infra/ changes (review-friendly diff)
#   - `infra-apply` — `tofu apply` on main merge с infra/ changes
#   - `deploy` — build + push backend image + revision deploy on main
#
# Auth: Service Connection (OIDC) → ephemeral IAM token per job. No SA keys
# в SourceCraft secrets — native YC integration ([Q2 2026 canon](https://yandex.cloud/en/docs/tutorials/serverless/ci-cd-sourcecraft-functions)).
#
# Service connection name: `deploy-connection` (create в SourceCraft UI →
# Настройки → Сервисные подключения → bind to YC folders infra + demo).

env:
  REGISTRY: 'cr.yandex/crprdhmq3p9f9a5j5ck6'
  IMAGE_NAME: 'backend'
  YDB_CONNECTION_STRING: 'grpcs://ydb.serverless.yandexcloud.net:2135/?database=/ru-central1/b1g444ngoknombq45l4t/etn2aoiar0iqened9e5a'

tokens:
  yc:
    service_connection: deploy-connection
    scope: org

# =============================================================================
# Triggers
# =============================================================================

on:
  push:
    - workflows: [quality, deploy]
      filter:
        branches: ['main']
        # Skip CI on docs-only changes — saves Free tier CI minutes
        paths: ['**', '!docs/**', '!**/*.md', '!.claude/**', '!CHANGELOG.md']
    - workflows: [infra-apply]
      filter:
        branches: ['main']
        paths: ['infra/**']

  pull_request:
    - workflows: [quality]
    - workflows: [infra-plan]
      filter:
        paths: ['infra/**']

# =============================================================================
# Workflows
# =============================================================================

workflows:
  # ---------------------------------------------------------------------------
  # QUALITY (PR + push) — typecheck + tests
  # ---------------------------------------------------------------------------
  quality:
    settings:
      timeout: 15m
    tasks:
      - name: install
        cube: docker
        image: node:24-alpine
        run:
          - corepack enable && corepack prepare pnpm@10.33.2 --activate
          - pnpm install --frozen-lockfile

      - name: typecheck
        cube: docker
        image: node:24-alpine
        needs: [install]
        run:
          - corepack enable && pnpm typecheck

      - name: test-fast
        cube: docker
        image: oven/bun:1.3.14-alpine
        needs: [install]
        run:
          - pnpm install --frozen-lockfile --prefer-offline
          - pnpm test:fast

      - name: lint
        cube: docker
        image: node:24-alpine
        needs: [install]
        run:
          - pnpm lint
          - pnpm format:check

  # ---------------------------------------------------------------------------
  # INFRA PLAN (PR with infra/ changes) — review-friendly tofu plan
  # ---------------------------------------------------------------------------
  infra-plan:
    settings:
      timeout: 10m
    tasks:
      - name: tofu-plan
        cube: docker
        image: ghcr.io/opentofu/opentofu:1.12.0
        env:
          YC_TOKEN: ${{ tokens.yc.iam_token }}
          AWS_ACCESS_KEY_ID: ${{ secrets.TF_BOT_S3_ACCESS_KEY_ID }}
          AWS_SECRET_ACCESS_KEY: ${{ secrets.TF_BOT_S3_SECRET_ACCESS_KEY }}
        run:
          - cd infra
          - tofu init
          - tofu plan -no-color | tee plan.txt
          - echo "Plan saved to plan.txt — review in PR comments"

  # ---------------------------------------------------------------------------
  # INFRA APPLY (main merge with infra/) — apply tofu changes
  # ---------------------------------------------------------------------------
  infra-apply:
    settings:
      timeout: 20m
    tasks:
      - name: tofu-apply
        cube: docker
        image: ghcr.io/opentofu/opentofu:1.12.0
        env:
          YC_TOKEN: ${{ tokens.yc.iam_token }}
          AWS_ACCESS_KEY_ID: ${{ secrets.TF_BOT_S3_ACCESS_KEY_ID }}
          AWS_SECRET_ACCESS_KEY: ${{ secrets.TF_BOT_S3_SECRET_ACCESS_KEY }}
        run:
          - cd infra
          - tofu init
          - tofu apply -auto-approve

  # ---------------------------------------------------------------------------
  # DEPLOY (main merge) — build + push backend image + revision deploy
  # ---------------------------------------------------------------------------
  deploy:
    settings:
      timeout: 30m
    tasks:
      - name: build-push
        cube: docker
        image: docker:27-cli
        env:
          YC_TOKEN: ${{ tokens.yc.iam_token }}
        run:
          - SHA=$(git rev-parse --short HEAD)
          - echo "${YC_TOKEN}" | docker login --username iam --password-stdin cr.yandex
          - >
            docker buildx build
            --platform linux/amd64
            -f apps/backend/Dockerfile
            -t ${REGISTRY}/${IMAGE_NAME}:${SHA}
            -t ${REGISTRY}/${IMAGE_NAME}:latest
            --push
            .

      - name: revision-deploy
        cube: yc-sls-container-deploy
        needs: [build-push]
        with:
          container-name: sochi-backend-demo
          folder-id: b1gcqa89an0n32mqpuvo
          image: ${{ env.REGISTRY }}/${{ env.IMAGE_NAME }}:${{ github.sha }}
