# =============================================================================
# Sochi HoReCa — SourceCraft CI/CD (Q2 2026 canon, 2026-05-20)
# =============================================================================
#
# Stankoff-v2 production-verified syntax (Apr-May 2026, ru-central1):
#   - `cubes:` plural list (NOT `cube:` singular)
#   - Native cube format: `image: + script:` (NOT GitHub Actions `uses:`/
#     `run:` — those mean different things в SourceCraft. Bridge form is
#     `action: yc-actions/<name>@vN` если nuжен GH-action.)
#   - YC auth via cube `get-iam-token` whose output `IAM_TOKEN` is
#     consumed downstream via `${{ cubes.get-iam-token.outputs.IAM_TOKEN }}`
#   - Service Connection name `deploy-connection` (create в SourceCraft UI
#     → Настройки → Сервисные подключения → bind to YC folders infra + demo)
#
# DRAFT status (2026-05-20): syntax canon-aligned vs stankoff but NOT
# end-to-end verified against THIS repo's SourceCraft project yet. Rename
# back к ci.yaml when:
#   - Service Connection `deploy-connection` created в SourceCraft UI
#   - Secrets configured: YC_CONTAINER_ID, YC_RUNTIME_SA_ID,
#     YC_LOCKBOX_SECRET_VERSION_ID
#   - Test PR runs `quality` workflow end-to-end green
#
# =============================================================================

env:
  REGISTRY: "cr.yandex/crprdhmq3p9f9a5j5ck6"
  IMAGE_NAME: "backend"

tokens:
  yc:
    service_connection: deploy-connection
    scope: org

# =============================================================================
# Triggers
# =============================================================================

on:
  push:
    - workflows: [quality, deploy-backend, deploy-frontend]
      filter:
        branches: ["main"]
        paths: ["**", "!docs/**", "!**/*.md", "!.claude/**", "!CHANGELOG.md"]
    - workflows: [infra-apply]
      filter:
        branches: ["main"]
        paths: ["infra/**"]

  pull_request:
    - workflows: [quality]
    - workflows: [infra-plan]
      filter:
        paths: ["infra/**"]

# =============================================================================
# Workflows
# =============================================================================

workflows:
  # ---------------------------------------------------------------------------
  # QUALITY (PR + push) — typecheck + tests + lint
  # ---------------------------------------------------------------------------
  quality:
    settings:
      timeout: 15m
    cubes:
      - name: install
        image:
          name: node:24-alpine
          entrypoint: ""
        script:
          - corepack enable && corepack prepare pnpm@10.33.2 --activate
          - pnpm install --frozen-lockfile

      - name: typecheck
        needs: [install]
        image:
          name: node:24-alpine
          entrypoint: ""
        script:
          - corepack enable && pnpm typecheck

      - name: test-fast
        needs: [install]
        image:
          name: oven/bun:1.3.14-alpine
          entrypoint: ""
        script:
          - pnpm install --frozen-lockfile --prefer-offline
          - pnpm test:fast

      - name: lint
        needs: [install]
        image:
          name: node:24-alpine
          entrypoint: ""
        script:
          - pnpm lint
          - pnpm format:check

  # ---------------------------------------------------------------------------
  # INFRA PLAN (PR with infra/ changes)
  # ---------------------------------------------------------------------------
  infra-plan:
    settings:
      timeout: 10m
    cubes:
      - name: get-iam-token
        image:
          name: cr.yandex/sourcecraft/yc-iam:latest
          entrypoint: ""
        env:
          YC_ID_TOKEN: ${{ tokens.yc.id_token }}
        outputs:
          - IAM_TOKEN

      - name: tofu-plan
        needs: [get-iam-token]
        image:
          name: ghcr.io/opentofu/opentofu:1.12.0
          entrypoint: ""
        env:
          YC_TOKEN: ${{ cubes.get-iam-token.outputs.IAM_TOKEN }}
          AWS_ACCESS_KEY_ID: ${{ secrets.TF_BOT_S3_ACCESS_KEY_ID }}
          AWS_SECRET_ACCESS_KEY: ${{ secrets.TF_BOT_S3_SECRET_ACCESS_KEY }}
        script:
          - cd infra
          - tofu init -input=false
          - tofu plan -no-color -input=false | tee plan.txt

  # ---------------------------------------------------------------------------
  # INFRA APPLY (main merge with infra/ changes)
  # ---------------------------------------------------------------------------
  infra-apply:
    settings:
      timeout: 20m
    cubes:
      - name: get-iam-token
        image:
          name: cr.yandex/sourcecraft/yc-iam:latest
          entrypoint: ""
        env:
          YC_ID_TOKEN: ${{ tokens.yc.id_token }}
        outputs:
          - IAM_TOKEN

      - name: tofu-apply
        needs: [get-iam-token]
        image:
          name: ghcr.io/opentofu/opentofu:1.12.0
          entrypoint: ""
        env:
          YC_TOKEN: ${{ cubes.get-iam-token.outputs.IAM_TOKEN }}
          AWS_ACCESS_KEY_ID: ${{ secrets.TF_BOT_S3_ACCESS_KEY_ID }}
          AWS_SECRET_ACCESS_KEY: ${{ secrets.TF_BOT_S3_SECRET_ACCESS_KEY }}
        script:
          - cd infra
          - tofu init -input=false
          - tofu apply -auto-approve -input=false

  # ---------------------------------------------------------------------------
  # DEPLOY BACKEND — build + push backend image + revision deploy
  # ---------------------------------------------------------------------------
  deploy-backend:
    settings:
      timeout: 30m
    cubes:
      - name: get-iam-token
        image:
          name: cr.yandex/sourcecraft/yc-iam:latest
          entrypoint: ""
        env:
          YC_ID_TOKEN: ${{ tokens.yc.id_token }}
        outputs:
          - IAM_TOKEN

      - name: build-push
        needs: [get-iam-token]
        image:
          name: docker:27-cli
          entrypoint: ""
        env:
          YC_TOKEN: ${{ cubes.get-iam-token.outputs.IAM_TOKEN }}
        script:
          - SHA=$(git rev-parse --short HEAD)
          - echo "${YC_TOKEN}" | docker login --username iam --password-stdin cr.yandex
          - docker buildx build --platform linux/amd64 --provenance=false
            -f apps/backend/Dockerfile
            -t ${REGISTRY}/${IMAGE_NAME}:${SHA}
            -t ${REGISTRY}/${IMAGE_NAME}:latest
            --push .

      - name: revision-deploy
        needs: [build-push]
        image:
          name: cr.yandex/sourcecraft/yc-cli:latest
          entrypoint: ""
        env:
          YC_TOKEN: ${{ cubes.get-iam-token.outputs.IAM_TOKEN }}
          YC_CONTAINER_NAME: ${{ secrets.YC_CONTAINER_NAME }}
          YC_FOLDER_ID: ${{ secrets.YC_DEMO_FOLDER_ID }}
          YC_RUNTIME_SA_ID: ${{ secrets.YC_RUNTIME_SA_ID }}
          YC_LOCKBOX_ID: ${{ secrets.YC_LOCKBOX_SECRET_ID }}
          YC_LOCKBOX_VERSION_ID: ${{ secrets.YC_LOCKBOX_VERSION_ID }}
          YDB_CONNECTION_STRING: ${{ secrets.YDB_CONNECTION_STRING }}
          S3_BUCKET: ${{ secrets.S3_BACKEND_FILES_BUCKET }}
        script:
          - SHA=$(git rev-parse --short HEAD)
          - yc serverless container revision deploy
            --container-name "$YC_CONTAINER_NAME"
            --folder-id "$YC_FOLDER_ID"
            --image "${REGISTRY}/${IMAGE_NAME}:${SHA}"
            --service-account-id "$YC_RUNTIME_SA_ID"
            --memory 1GB --cores 1 --core-fraction 100
            --concurrency 4 --execution-timeout 30s --min-instances 2
            --environment APP_MODE=sandbox
            --environment NODE_ENV=production
            --environment LOG_LEVEL=info
            --environment DEMO_DEPLOYMENT=true
            --environment HOST=demo.sepshn.ru
            --environment PUBLIC_BASE_URL=https://demo.sepshn.ru
            --environment BETTER_AUTH_URL=https://demo.sepshn.ru
            --environment BETTER_AUTH_TRUSTED_ORIGINS=https://demo.sepshn.ru
            --environment YDB_CONNECTION_STRING="$YDB_CONNECTION_STRING"
            --environment YDB_METADATA_CREDENTIALS=1
            --environment PAYMENT_PROVIDER=stub
            --environment VISION_PROVIDER=mock
            --environment POSTBOX_ENABLED=false
            --environment APP_MODE_PERMITTED_MOCK_ADAPTERS="email.demo-inbox,sms.demo-inbox,payment.stub,vision.mock"
            --environment S3_ENDPOINT=https://storage.yandexcloud.net
            --environment S3_REGION=ru-central1
            --environment S3_BUCKET="$S3_BUCKET"
            --environment EMAIL_FROM_ADDRESS=noreply@demo.sepshn.ru
            --environment EMAIL_FROM_NAME="Sochi HoReCa Demo"
            --secret id=$YC_LOCKBOX_ID,version-id=$YC_LOCKBOX_VERSION_ID,key=BETTER_AUTH_SECRET,environment-variable=BETTER_AUTH_SECRET
            --secret id=$YC_LOCKBOX_ID,version-id=$YC_LOCKBOX_VERSION_ID,key=S3_ACCESS_KEY_ID,environment-variable=S3_ACCESS_KEY_ID
            --secret id=$YC_LOCKBOX_ID,version-id=$YC_LOCKBOX_VERSION_ID,key=S3_SECRET_ACCESS_KEY,environment-variable=S3_SECRET_ACCESS_KEY

  # ---------------------------------------------------------------------------
  # DEPLOY FRONTEND — Vite build + aws s3 sync с two-pass Cache-Control canon
  # ---------------------------------------------------------------------------
  deploy-frontend:
    settings:
      timeout: 15m
    cubes:
      - name: get-iam-token
        image:
          name: cr.yandex/sourcecraft/yc-iam:latest
          entrypoint: ""
        env:
          YC_ID_TOKEN: ${{ tokens.yc.id_token }}
        outputs:
          - IAM_TOKEN

      - name: build
        image:
          name: node:24-alpine
          entrypoint: ""
        script:
          - corepack enable && corepack prepare pnpm@10.33.2 --activate
          - pnpm install --frozen-lockfile
          - pnpm --filter @horeca/frontend build

      - name: upload
        needs: [build]
        image:
          name: amazon/aws-cli:latest
          entrypoint: ""
        env:
          AWS_ACCESS_KEY_ID: ${{ secrets.FRONTEND_S3_ACCESS_KEY_ID }}
          AWS_SECRET_ACCESS_KEY: ${{ secrets.FRONTEND_S3_SECRET_ACCESS_KEY }}
          S3_BUCKET: ${{ secrets.FRONTEND_S3_BUCKET }}
        script:
          # Pass 1: hashed assets — immutable, max-age=1 year
          - aws --endpoint-url=https://storage.yandexcloud.net s3 sync
            apps/frontend/dist/ s3://${S3_BUCKET}/
            --exclude "*" --include "assets/*"
            --cache-control "public, max-age=31536000, immutable"
            --delete
          # Pass 2: PWA icons + manifest images — day cache
          - aws --endpoint-url=https://storage.yandexcloud.net s3 sync
            apps/frontend/dist/ s3://${S3_BUCKET}/
            --exclude "*"
            --include "*.png" --include "*.svg" --include "*.ico"
            --cache-control "public, max-age=86400"
          # Pass 3: index.html + service worker + manifest — no-cache (always revalidate)
          - aws --endpoint-url=https://storage.yandexcloud.net s3 sync
            apps/frontend/dist/ s3://${S3_BUCKET}/
            --exclude "*"
            --include "index.html"
            --include "sw.js"
            --include "workbox-*.js"
            --include "manifest.webmanifest"
            --include "registerSW.js"
            --cache-control "no-cache, must-revalidate"
