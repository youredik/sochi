{
	"name": "horeca-portal",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm --parallel --filter './apps/*' dev",
		"build": "pnpm -r --filter './apps/*' --filter './packages/*' build",
		"typecheck": "run-p typecheck:tsgo:*",
		"typecheck:tsgo:backend": "tsgo --noEmit -p apps/backend/tsconfig.json",
		"typecheck:tsgo:frontend": "tsgo --noEmit -p apps/frontend/tsconfig.json",
		"typecheck:tsgo:widget": "tsgo --noEmit -p apps/widget-embed/tsconfig.json",
		"typecheck:tsgo:shared": "tsgo --noEmit -p packages/shared/tsconfig.json",
		"tsgo:diff": "node scripts/tsgo-diff.ts",
		"tsgo:sweep": "node scripts/tsgo-diff-sweep.ts",
		"oxlint": "oxlint",
		"oxlint:types": "oxlint --type-aware",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"test": "run-s test:fast test:db",
		"test:fast": "run-p test:fast:backend test:fast:frontend test:fast:widget",
		"test:fast:backend": "cd apps/backend && bun test --parallel --path-ignore-patterns='**/*.db.test.ts'",
		"test:fast:frontend": "cd apps/frontend && bun test --parallel",
		"test:fast:widget": "cd apps/widget-embed && pnpm test",
		"test:db": "cd apps/backend && bun test --parallel src/**/*.db.test.ts",
		"test:serial": "cd apps/backend && bun test src/**/*.db.test.ts",
		"test:watch": "cd apps/backend && bun test --watch",
		"test:unit": "pnpm test:fast",
		"test:full": "run-s test:fast test:db",
		"test:changed": "cd apps/backend && bun test --parallel --changed=origin/main",
		"doctor": "node --env-file-if-exists=.env scripts/dev-doctor.ts",
		"coverage": "cd apps/backend && bun test --coverage src/**/*.test.ts",
		"sherif": "sherif",
		"knip": "knip",
		"depcruise": "depcruise --config .dependency-cruiser.mjs apps/ packages/",
		"infra:up": "docker compose up -d",
		"infra:down": "docker compose down",
		"infra:reset": "docker compose down -v && docker compose up -d && pnpm migrate",
		"infra:verify": "./scripts/verify-infra.sh",
		"migrate": "node --env-file-if-exists=.env apps/backend/src/db/apply-migrations.ts && pnpm seed:constants && pnpm backfill",
		"seed:constants": "node --env-file-if-exists=.env apps/backend/src/db/seed-system-constants.ts",
		"seed:demo": "node --env-file-if-exists=.env apps/backend/src/db/seed-demo-tenant.ts",
		"backfill": "node --env-file-if-exists=.env apps/backend/src/db/backfill-folios.ts",
		"smoke": "node --env-file-if-exists=.env scripts/smoke.ts",
		"smoke:fresh": "pnpm infra:reset && pnpm smoke",
		"e2e": "playwright test",
		"e2e:smoke": "playwright test --reporter=line",
		"e2e:install": "playwright install chromium",
		"walkthrough": "node --env-file-if-exists=.env scripts/walkthrough/record.ts",
		"tts:test": "node --env-file-if-exists=.env scripts/walkthrough/test-tts.ts",
		"size:check": "size-limit",
		"lhci:collect": "lhci autorun",
		"mutate": "stryker run"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.3",
		"@biomejs/biome": "^2.4.15",
		"@lhci/cli": "0.15.1",
		"@playwright/test": "1.61.0-alpha-2026-05-13",
		"@size-limit/preset-app": "^12.1.0",
		"@stryker-mutator/core": "^9.6.1",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.7.0",
		"@typescript/native-preview": "7.0.0-dev.20260513.1",
		"axe-core": "4.11.4",
		"bun": "^1.3.14",
		"dependency-cruiser": "^17.4.0",
		"knip": "^6.13.1",
		"lefthook": "^2.1.6",
		"npm-run-all2": "^8.0.4",
		"oxfmt": "^0.49.0",
		"oxlint": "^1.64.0",
		"oxlint-tsgolint": "^0.22.1",
		"sherif": "^1.11.1",
		"size-limit": "^12.1.0",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@10.33.2",
	"pnpm": {
		"onlyBuiltDependencies": [
			"bun",
			"esbuild",
			"lefthook",
			"sharp"
		],
		"overrides": {
			"serialize-javascript": "^7.0.5",
			"protobufjs@<8.0.2": "^8.2.0",
			"rimraf@<4": "^6.1.3",
			"glob@<13": "^13.0.6",
			"uuid@<11": "^11.1.0",
			"workbox-build>source-map": "^0.7.6"
		},
		"patchedDependencies": {
			"sharp@0.35.0-rc.5": "patches/sharp@0.35.0-rc.5.patch"
		}
	}
}
