{
	"name": "horeca-portal",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@10.33.2",
	"scripts": {
		"dev": "pnpm --parallel --filter './apps/*' dev",
		"build": "pnpm -r --filter './apps/*' --filter './packages/*' build",
		"typecheck": "run-p typecheck:tsgo:*",
		"typecheck:fallback": "run-p typecheck:tsc:*",
		"typecheck:tsc:backend": "tsc --noEmit -p apps/backend/tsconfig.json",
		"typecheck:tsc:frontend": "tsc --noEmit -p apps/frontend/tsconfig.json",
		"typecheck:tsc:widget": "tsc --noEmit -p apps/widget-embed/tsconfig.json",
		"typecheck:tsc:shared": "tsc --noEmit -p packages/shared/tsconfig.json",
		"typecheck:tsgo:backend": "tsgo --noEmit -p apps/backend/tsconfig.json",
		"typecheck:tsgo:frontend": "tsgo --noEmit -p apps/frontend/tsconfig.json",
		"typecheck:tsgo:widget": "tsgo --noEmit -p apps/widget-embed/tsconfig.json",
		"typecheck:tsgo:shared": "tsgo --noEmit -p packages/shared/tsconfig.json",
		"tsgo:diff": "node scripts/tsgo-diff.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:serial": "vitest run --no-file-parallelism",
		"test:full": "vitest run --no-file-parallelism",
		"test:watch": "vitest",
		"test:unit": "vitest run --tags-filter=\"!db\"",
		"test:fast": "vitest run --tags-filter=\"!db\"",
		"test:db": "vitest run --tags-filter=\"db\" --no-file-parallelism",
		"test:changed": "vitest run --changed --tags-filter=\"!db\"",
		"doctor": "node --env-file-if-exists=.env scripts/dev-doctor.ts",
		"coverage": "vitest run --coverage --no-file-parallelism",
		"mutate": "stryker run",
		"sherif": "sherif",
		"knip": "knip",
		"depcruise": "depcruise --config .dependency-cruiser.mjs apps/ packages/",
		"infra:up": "docker compose up -d",
		"infra:down": "docker compose down",
		"infra:reset": "docker compose down -v && docker compose up -d && pnpm migrate",
		"infra:verify": "./scripts/verify-infra.sh",
		"migrate": "node --env-file-if-exists=.env apps/backend/src/db/apply-migrations.ts && pnpm seed:constants && pnpm backfill",
		"seed:constants": "node --env-file-if-exists=.env apps/backend/src/db/seed-system-constants.ts",
		"seed:demo": "node --env-file-if-exists=.env apps/backend/src/db/seed-demo-tenant.ts",
		"backfill": "node --env-file-if-exists=.env apps/backend/src/db/backfill-folios.ts",
		"smoke": "node --env-file-if-exists=.env scripts/smoke.ts",
		"smoke:fresh": "pnpm infra:reset && pnpm smoke",
		"e2e": "playwright test",
		"e2e:smoke": "playwright test --workers=1 --reporter=line",
		"e2e:install": "playwright install chromium",
		"walkthrough": "node --env-file-if-exists=.env scripts/walkthrough/record.ts",
		"tts:test": "node --env-file-if-exists=.env scripts/walkthrough/test-tts.ts",
		"size:check": "size-limit",
		"lhci:collect": "lhci autorun"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.3",
		"@biomejs/biome": "^2.4.15",
		"@lhci/cli": "0.15.1",
		"@playwright/test": "^1.60.0",
		"@size-limit/preset-app": "^12.1.0",
		"@stryker-mutator/core": "^9.6.1",
		"@stryker-mutator/vitest-runner": "^9.6.1",
		"@types/node": "^25.7.0",
		"@typescript/native-preview": "7.0.0-dev.20260512.1",
		"@vitest/coverage-v8": "^4.1.6",
		"axe-core": "4.11.4",
		"dependency-cruiser": "^17.4.0",
		"knip": "^6.13.0",
		"lefthook": "^2.1.6",
		"npm-run-all2": "^8.0.4",
		"sherif": "^1.11.1",
		"size-limit": "^12.1.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lefthook",
			"sharp"
		],
		"overrides": {
			"serialize-javascript": "^7.0.5"
		}
	}
}
