# =============================================================================
# HoReCa SaaS — local development environment variables
# Copy this file to .env and customize where needed.
# =============================================================================

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- PWA + WebAuthn host identity (M9.4) ---
# HOST: bare hostname WITHOUT protocol/port — WebAuthn rpID requirement.
# PUBLIC_BASE_URL: full origin для passkey origin parameter.
HOST=localhost
PUBLIC_BASE_URL=http://localhost:5173

# --- YDB (local single-node in docker-compose, host port 2236) ---
YDB_CONNECTION_STRING=grpc://localhost:2236/local

# --- Better Auth ---
# Generate once: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173

# --- S3-compatible storage (local MinIO in dev, host port 9100 | Yandex Object Storage in prod) ---
S3_ENDPOINT=http://localhost:9100
S3_REGION=ru-central1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=horeca-files

# --- SMTP (Mailpit in dev, host port 1125 | Yandex Postbox in prod) ---
SMTP_HOST=localhost
SMTP_PORT=1125
EMAIL_FROM_ADDRESS=noreply@horeca.local
EMAIL_FROM_NAME=HoReCa

# --- Prod-only (Yandex Postbox SESv2) — leave empty locally ---
POSTBOX_ENABLED=false
POSTBOX_ACCESS_KEY_ID=
POSTBOX_SECRET_ACCESS_KEY=
POSTBOX_ENDPOINT=https://postbox.cloud.yandex.net

# --- Frontend (Vite; VITE_* vars are exposed to the browser) ---
# Leave VITE_API_URL blank to use same-origin (Vite dev proxy forwards /api/*
# to the Hono backend at PORT above). Set explicitly in prod for the
# `app.*.ru → api.*.ru` cross-subdomain pattern.
VITE_API_URL=

# --- OpenTelemetry Collector (prod forwarder for /api/otel/v1/traces) ---
# Leave blank in dev — backend logs-and-discards OTLP ingest.
# In prod point to Yandex Cloud Tracing OTLP endpoint (152-ФЗ residency).
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Yandex SpeechKit (used by `pnpm walkthrough` + `pnpm tts:test`) ---
# Optional — if set, walkthrough TTS swaps from macOS `say` (Milena) to
# Yandex SpeechKit with voice "alyss" (canonical Алиса). Setup:
#   1. YC Console → IAM → Service Accounts → create SA with role
#      `ai.speechkit-user` (or `editor`).
#   2. SA → "Создать API-ключ" → copy.
#   3. Folder ID: top of YC console URL (b1g...).
# YC_FOLDER_ID=
# YC_API_KEY=
# Optional voice override. Other RU options: alena (corporate-female),
# jane (softer-female), ermil (male-announcer), filipp (male-deep)
# YC_TTS_VOICE=alyss
# Optional speed override (0.1..3.0, default 1.0)
# YC_TTS_SPEED=1.0
