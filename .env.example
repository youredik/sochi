# =============================================================================
# HoReCa SaaS — local development environment variables
# Copy this file to .env and customize where needed.
# =============================================================================

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- YDB (local single-node in docker-compose, host port 2236) ---
YDB_CONNECTION_STRING=grpc://localhost:2236/local

# --- Better Auth ---
# Generate once: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173

# --- S3-compatible storage (local MinIO in dev, host port 9100 | Yandex Object Storage in prod) ---
S3_ENDPOINT=http://localhost:9100
S3_REGION=ru-central1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=horeca-files

# --- SMTP (Mailpit in dev, host port 1125 | Yandex Postbox in prod) ---
SMTP_HOST=localhost
SMTP_PORT=1125
EMAIL_FROM_ADDRESS=noreply@horeca.local
EMAIL_FROM_NAME=HoReCa

# --- Prod-only (Yandex Postbox SESv2) — leave empty locally ---
POSTBOX_ENABLED=false
POSTBOX_ACCESS_KEY_ID=
POSTBOX_SECRET_ACCESS_KEY=
POSTBOX_ENDPOINT=https://postbox.cloud.yandex.net
