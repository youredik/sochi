{
	"name": "@horeca/backend",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"exports": {
		"./app": {
			"types": "./src/app.ts",
			"default": "./src/app.ts"
		}
	},
	"files": ["src", "package.json"],
	"scripts": {
		"dev": "node --watch --watch-preserve-output --env-file-if-exists=../../.env src/index.ts",
		"start": "node src/index.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1035.0",
		"@aws-sdk/client-sesv2": "^3.1035.0",
		"@hono/node-server": "^2.0.0",
		"@hono/zod-validator": "^0.7.6",
		"@horeca/shared": "workspace:*",
		"@ydbjs/auth": "6.2.1",
		"@ydbjs/core": "6.1.0",
		"@ydbjs/error": "6.0.5",
		"@ydbjs/query": "6.0.7",
		"@ydbjs/retry": "6.2.0",
		"@ydbjs/value": "6.0.5",
		"better-auth": "^1.6.7",
		"hono": "^4.12.14",
		"pino": "^10.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"pino-pretty": "^13.1.3",
		"vitest": "^4.1.5"
	}
}
