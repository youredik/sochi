{
	"name": "@horeca/backend",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"exports": {
		"./app": {
			"types": "./src/app.ts",
			"default": "./src/app.ts"
		},
		"./auth": {
			"types": "./src/auth.ts",
			"default": "./src/auth.ts"
		}
	},
	"files": [
		"src",
		"package.json"
	],
	"scripts": {
		"dev": "node --watch --watch-preserve-output --env-file-if-exists=../../.env src/index.ts",
		"start": "node src/index.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1038.0",
		"@aws-sdk/client-sesv2": "^3.1040.0",
		"@aws-sdk/s3-request-presigner": "^3.1038.0",
		"@better-auth/passkey": "^1.6.9",
		"@hono/node-server": "^2.0.0",
		"@hono/zod-validator": "^0.7.6",
		"@horeca/shared": "workspace:*",
		"@ydbjs/auth": "6.2.1",
		"@ydbjs/core": "6.1.1",
		"@ydbjs/error": "6.0.5",
		"@ydbjs/query": "6.1.0",
		"@ydbjs/topic": "6.1.2",
		"@ydbjs/value": "6.0.7",
		"better-auth": "^1.6.9",
		"croner": "^10.0.1",
		"fflate": "0.8.2",
		"hono": "^4.12.16",
		"hono-pino": "^0.10.3",
		"hono-rate-limiter": "0.5.3",
		"ical-generator": "^10.2.0",
		"jose": "^6.2.3",
		"pino": "^10.3.1",
		"sharp": "^0.34.5",
		"timezones-ical-library": "^2.2.0",
		"write-excel-file": "^4.0.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@fast-check/vitest": "^0.4.1",
		"@types/node": "^25.6.0",
		"node-ical": "^0.26.0",
		"pino-pretty": "^13.1.3",
		"read-excel-file": "^9.0.6",
		"vitest": "^4.1.5"
	}
}
