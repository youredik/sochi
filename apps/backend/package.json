{
	"name": "@horeca/backend",
	"version": "0.0.1",
	"private": true,
	"files": [
		"src",
		"package.json"
	],
	"type": "module",
	"exports": {
		"./app": {
			"types": "./src/app.ts",
			"default": "./src/app.ts"
		},
		"./auth": {
			"types": "./src/auth.ts",
			"default": "./src/auth.ts"
		}
	},
	"scripts": {
		"dev": "bun --watch --env-file=../../.env src/index.ts",
		"start": "bun src/index.ts",
		"build": "tsgo -p tsconfig.build.json",
		"build:native": "bun build --compile --bytecode --minify --sourcemap --target=bun-linux-x64-baseline --outfile ./dist/sochi-api src/index.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1053.0",
		"@aws-sdk/client-sesv2": "^3.1053.0",
		"@aws-sdk/s3-request-presigner": "^3.1053.0",
		"@better-auth/passkey": "^1.6.11",
		"@hono/node-server": "^2.0.4",
		"@hono/zod-validator": "^0.8.0",
		"@horeca/shared": "workspace:*",
		"@opentelemetry/api": "^1.9.1",
		"@ydbjs/auth": "6.3.0",
		"@ydbjs/core": "6.2.0",
		"@ydbjs/error": "6.0.5",
		"@ydbjs/query": "6.2.0",
		"@ydbjs/topic": "6.1.3",
		"@ydbjs/value": "6.0.7",
		"amaro": "^1.1.9",
		"better-auth": "^1.6.11",
		"cloudevents": "10.0.0",
		"cockatiel": "^3.2.1",
		"croner": "^10.0.1",
		"fflate": "0.8.3",
		"hono": "^4.12.23",
		"hono-pino": "^0.10.3",
		"hono-rate-limiter": "0.5.3",
		"ical-generator": "^10.2.0",
		"jose": "^6.2.3",
		"lru-cache": "11.5.0",
		"mrz": "5.0.2",
		"pino": "^10.3.1",
		"sharp": "0.34.5",
		"timezones-ical-library": "^2.2.0",
		"write-excel-file": "^4.0.7",
		"zod": "4.5.0-canary.20260504T180558"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/node": "^25.7.0",
		"fast-check": "^4.8.0",
		"msw": "2.14.6",
		"node-ical": "^0.26.1",
		"pino-pretty": "^13.1.3",
		"read-excel-file": "^9.0.10"
	}
}
